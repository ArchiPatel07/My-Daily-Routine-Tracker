import json
import os
import random

DATA_FILE = "data.json"

def load_data():
    if not os.path.exists(DATA_FILE):
        return []
    try:
        with open(DATA_FILE, "r") as f:
            return json.load(f)
    except:
        return []


def save_data(data):
    with open(DATA_FILE, "w") as f:
        json.dump(data, f, indent=4)


def get_number(msg):
    while True:
        try:
            val = float(input(msg))
            if val < 0:
                print("Value cannot be negative.")
                continue
            return val
        except:
            print("Enter a valid number.")


def get_mood():
    moods = ["happy", "normal" , "tired", "stressed"]
    while True:
        mood = input("Mood (happy/normal/tired/stressed): ").lower()
        if mood in moods:
            return mood
        print("Invalid mood.")


# ---------- ADD ENTRY ----------
def add_entry(data):
    print("\n--- Add Entry ---")

    day = input("Enter day (Mon/Tue etc): ")
    study = get_number("Study hours: ")
    college = get_number("College time in hours: ")
    sleep = get_number("Sleep hours: ")
    screen = get_number("Screen time: ")
    mood = get_mood()

    entry = {
        "day": day,
        "study": study,
        "college": college,
        "sleep": sleep,
        "screen": screen,
        "mood": mood
    }

    data.append(entry)
    save_data(data)

    print("Entry saved successfully!\n")
# ---------- VIEW ----------
def view_entries(data):
    print("\n--- All Entries ---")

    if not data:
        print("No data available.\n")
        return

    for i, e in enumerate(data, 1):
       print(f"{i}. {e.get('day','-')} | Study: {e.get('study',0)}h | College: {e.get('college',0)}h | Sleep: {e.get('sleep',0)}h | Screen: {e.get('screen',0)}h | Mood: {e.get('mood','-')}")
    print()
# ---------- DELETE ----------
def delete_entry(data):
    view_entries(data)

    if not data:
        return

    try:
        choice = int(input("Enter entry number to delete: "))
        if 1 <= choice <= len(data):
            removed = data.pop(choice - 1)
            save_data(data)
            print(f"Deleted entry for {removed['day']}\n")
        else:
            print("Invalid choice.\n")
    except:
        print("Enter a valid number.\n")


# ---------- ANALYSIS ----------
def analyze_data(data):
    print("\n--- Analysis Report ---")

    if not data:
        print("No data to analyze.\n")
        return

    total_study = sum(d.get("study", 0) for d in data)
    total_sleep = sum(d.get("sleep", 0) for d in data)
    total_college = sum(d.get("college", 0) for d in data)
    total_screen = sum(d.get("screen", 0) for d in data)

    avg_study = total_study / len(data)
    avg_college = total_college / len(data)
    avg_sleep = total_sleep / len(data)
    avg_screen = total_screen / len(data)

    print(f"Average Study Hours: {avg_study:.2f}")
    print(f"Average College Hours: {avg_college:.2f}")
    print(f"Average Sleep Hours: {avg_sleep:.2f}")
    print(f"Average Screen Time: {avg_screen:.2f}")

    best_day = max(data, key=lambda x: x.get("study", 0))
    print(f"Most Productive Day: {best_day.get('day')}")

    mood_count = {}
    for d in data:
        mood = d.get("mood", "unknown")
        mood_count[mood] = mood_count.get(mood, 0) + 1
    print("\nMood Distribution:")
    for mood, count in mood_count.items():
        print(f"{mood}: {count} days")
    # Productivity Score
    score = avg_college + avg_study - (0.5 * avg_screen)
    print(f"Productivity Score: {score:.2f}")

    print("\n--- Insights ---")

    if avg_study < 2:
        print("I think I need to study more")
    elif avg_study > 5:
        print("Good job! study is going well")
    else:
        print("Study is okay, can improve")

    if avg_sleep < 6:
        print("You need better sleep.")
    elif avg_sleep > 9 :
        print("More sleep can make you feel tired")
    else:
        print("Sleep schedule is okay.")

    if avg_screen > 5:
        print("Too much instagram aand youtube can destroy your placements")

    print()


