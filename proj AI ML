# ---------- SMART PREDICTION (ML-LIKE) ----------
def predict_mood(data):
    print("\n--- Smart Mood Prediction ---")

    if len(data) < 3:
        print("Add more data for better prediction.\n")
        return

    study = get_number("Study hours: ")
    sleep = get_number("Sleep hours: ")
    screen = get_number("Screen time: ")
    college = get_number("College time: ")

    avg_study = sum(d.get("study", 0) for d in data) / len(data)
    avg_sleep = sum(d.get("sleep", 0) for d in data) / len(data)
    avg_screen = sum(d.get("screen", 0) for d in data) / len(data)
    avg_college = sum(d.get("college", 0) for d in data) / len(data)

    avg_study = avg_study if avg_study != 0 else 1
    avg_sleep = avg_sleep if avg_sleep != 0 else 1
    avg_screen = avg_screen if avg_screen != 0 else 1
    avg_college = avg_college if avg_college != 0 else 1

    score = (
        (study / avg_study) * 2 +
        (sleep / avg_sleep) * 1.5 +
        (college / avg_college) * 1.5 -
        (screen / avg_screen) * 2
    )

    if score > 20:
        mood = "happy"
    elif score > 13:
        mood = "normal"
    elif score > 7:
        mood = "tired"
    else:
        mood = "stressed"

    print(f"\nPredicted Mood: {mood}")

    # Suggestions
    if mood == "stressed":
        print("Suggestion: Reduce screen time and take breaks.")
    elif mood == "tired":
        print("Suggestion: Needs to improve your schedule.")
    elif mood == "normal":
        print("Suggestion: Good but can be improved.")
    else:
        print("Suggestion: Keep following this routine.")

    print()

# ---------- EXTRA FEATURE ----------
def weekly_summary(data):
    print("\n--- Weekly Summary ---")

    if len(data) < 7:
        print("Add at least 7 entries for weekly summary.\n")
        return

    last_week = data[-7:]

    total_study = sum(d.get("study", 0) for d in last_week)
    total_college = sum(d.get("college", 0) for d in last_week)
    total_sleep = sum(d.get("sleep", 0) for d in last_week)

    print(f"Total Study (Last 7 days): {total_study} hrs")
    print(f"Total Sleep (Last 7 days): {total_sleep} hrs")
    print(f"Total College (Last 7 days): {total_college} hrs")

    print()


# ---------- MAIN ----------
def main():
    data = load_data()

    while True:
        print("====== My Daily Routine Tracker ======")
        print("1. Add Entry")
        print("2. View Entries")
        print("3. Analyze Data")
        print("4. Delete Entry")
        print("5. Predict Mood")
        print("6. Weekly Summary")
        print("7. Motivation")
        print("8. Exit")

        choice = input("Enter your choice: ")

        if choice == "1":
            add_entry(data)
        elif choice == "2":
            view_entries(data)
        elif choice == "3":
            analyze_data(data)
        elif choice == "4":
            delete_entry(data)
        elif choice == "5":
            predict_mood(data)
        elif choice == "6":
            weekly_summary(data)
        elif choice == "7":
            motivation()
        elif choice == "8":
            print("Goodbye!")
            break
        else:
            print("Invalid choice.\n")


if __name__ == "__main__":
    main()